# Local Development Environment Configuration
# For local development with backend running on localhost:3000

REACT_APP_ENVIRONMENT=development
REACT_APP_BACKEND_URL=http://localhost:3000
REACT_APP_FRONTEND_URL=http://localhost:3001
REACT_APP_ENABLE_DEBUG_LOGGING=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=false
REACT_APP_STAGING_BANNER=false
NODE_ENV=development

# Optional: Smart routing threshold for file uploads (4MB default)
REACT_APP_SMART_ROUTING_THRESHOLD=4194304

# Optional: Enable mock API mode for development without backend
# REACT_APP_FORCE_MOCK_API=false